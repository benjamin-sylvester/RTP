# Copy to .env and fill in. Never commit .env.

# Postgres (Railway provides this)
DATABASE_URL=postgresql://user:pass@host:5432/rtp_deal_intel

# Claude API (extraction + summaries)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# Gmail (OAuth2 for the connected inbox)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_DEAL_FLOW_LABEL=Deal Flow

# Geocoding (Census is free; Google is fallback)
GOOGLE_MAPS_API_KEY=

# Dispatch channel = email (no Slack). Briefings/alerts are emailed.
# The app sends via the Gmail API creds above. Set the recipient:
DISPATCH_EMAIL=ben@rtprei.com

# Ingestion cadence
INGEST_INTERVAL_MINUTES=15

# Dashboard
DASHBOARD_PASSWORD=
DASHBOARD_SECRET_KEY=
DASHBOARD_HTTPS=true   # set true on Railway (HTTPS); false for local http
